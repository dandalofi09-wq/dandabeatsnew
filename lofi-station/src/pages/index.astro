---
import BaseLayout from '../layouts/BaseLayout.astro';
import YouTubeCustom from '../components/YouTubeCustom.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .sort((a: any, b: any) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<BaseLayout title="Música e Foco" description="Os melhores beats para o seu dia.">
  <section style="text-align: center; padding: 4rem 0;">
    <h1 style="font-size: 3rem; margin-bottom: 1rem;">O seu refúgio <span style="color: var(--accent)">lo-fi</span>.</h1>
    <p style="font-size: 1.2rem; max-width: 600px; margin: 0 auto 2rem;">Músicas calmas, ruído de chuva e jazzhop para ajudar você a estudar, focar no código ou apenas relaxar.</p>
    <a href="/posts" class="btn">Ouvir agora</a>
  </section>

  <section>
    <h2>Destaque da Semana</h2>
    <YouTubeCustom id="jfKfPfyJRdk" title="Lofi Girl Radio" />
  </section>

  <section style="margin-top: 4rem;">
    <h2>Últimas Playlists</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
      {recentPosts.map((post: any) => (
        <article class="card">
          <p class="tag" style="display:inline-block; margin-bottom: 0.5rem;">{post.data.category}</p>
          <h3><a href={`/posts/${post.slug}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            {post.data.tags?.map((tag: any) => <span style="font-size:0.75rem; color:var(--accent);">#{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>